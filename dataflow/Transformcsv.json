{
	"name": "Transformcsv",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DataFlowSource",
						"type": "DatasetReference"
					},
					"name": "sourceCSV"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "dataflow_sink",
						"type": "DatasetReference"
					},
					"name": "sinkdataflow"
				}
			],
			"transformations": [
				{
					"name": "selectCols"
				},
				{
					"name": "filterRows"
				},
				{
					"name": "splitData"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "aggregate",
					"description": "Add  aggregate columns"
				},
				{
					"name": "alterRows"
				}
			],
			"scriptLines": [
				"source(output(",
				"          transaction_id as short,",
				"          transactional_date as timestamp,",
				"          product_id as string,",
				"          customer_id as short,",
				"          payment as string,",
				"          credit_card as long,",
				"          loyalty_card as boolean,",
				"          cost as double,",
				"          quantity as short,",
				"          price as double",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceCSV",
				"sourceCSV select(mapColumn(",
				"          transaction_id,",
				"          transactional_date,",
				"          product_id,",
				"          customer_id,",
				"          payment,",
				"          price",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectCols",
				"selectCols filter(customer_id != 12) ~> filterRows",
				"filterRows split(payment == 'visa',",
				"     payment == 'mastercard',",
				"     disjoint: false) ~> splitData@(visa, mastercard, amex)",
				"splitData@amex derive(payment = coalesce(payment,'N/A')) ~> derivedColumn1",
				"splitData@visa aggregate(groupBy(customer_id),",
				"     product_id = max(product_id)) ~> aggregate",
				"aggregate alterRow(insertIf(1==1)) ~> alterRows",
				"alterRows sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkdataflow"
			]
		}
	}
}