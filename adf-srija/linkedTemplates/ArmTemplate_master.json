{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-srija"
		},
		"AzureSqlDatabase_sri_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'AzureSqlDatabase_sri'"
		},
		"linkedserviceAzureDataLake_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'linkedserviceAzureDataLake'"
		},
		"AzureSqlDatabase_sri_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "dfproservr.database.windows.net"
		},
		"AzureSqlDatabase_sri_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "DatabaseSri"
		},
		"AzureSqlDatabase_sri_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sriadmin"
		},
		"Linked_git_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://raw.githubusercontent.com"
		},
		"linkedserviceAzureDataLake_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://storagedatafactsrija.dfs.core.windows.net/"
		},
		"ls_rest_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://pokeapi.co/api/v2/pokemon"
		},
		"StorageEvntTrigg_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/0a9f1bae-2e42-40bd-b26e-f9e5e16a3597/resourceGroups/RG_SRI_ADF/providers/Microsoft.Storage/storageAccounts/storagedatafactsrija"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-srija_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureSqlDatabase_sri_password": {
						"value": "[parameters('AzureSqlDatabase_sri_password')]"
					},
					"linkedserviceAzureDataLake_accountKey": {
						"value": "[parameters('linkedserviceAzureDataLake_accountKey')]"
					},
					"AzureSqlDatabase_sri_properties_typeProperties_server": {
						"value": "[parameters('AzureSqlDatabase_sri_properties_typeProperties_server')]"
					},
					"AzureSqlDatabase_sri_properties_typeProperties_database": {
						"value": "[parameters('AzureSqlDatabase_sri_properties_typeProperties_database')]"
					},
					"AzureSqlDatabase_sri_properties_typeProperties_userName": {
						"value": "[parameters('AzureSqlDatabase_sri_properties_typeProperties_userName')]"
					},
					"Linked_git_properties_typeProperties_url": {
						"value": "[parameters('Linked_git_properties_typeProperties_url')]"
					},
					"linkedserviceAzureDataLake_properties_typeProperties_url": {
						"value": "[parameters('linkedserviceAzureDataLake_properties_typeProperties_url')]"
					},
					"ls_rest_properties_typeProperties_url": {
						"value": "[parameters('ls_rest_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "adf-srija_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"StorageEvntTrigg_properties_typeProperties_scope": {
						"value": "[parameters('StorageEvntTrigg_properties_typeProperties_scope')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'adf-srija_ArmTemplate_0')]"
			]
		}
	]
}